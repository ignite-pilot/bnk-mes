# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CloudWatch Logs (설정 시 로그 전송)
# CLOUDWATCH_LOG_GROUP=/bnk-mes/app
# CLOUDWATCH_REGION=ap-northeast-2
# CLOUDWATCH_LOG_STREAM=optional-stream-name
# AWS 인증: IAM 역할 또는 AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

# ig-member 화면 연동 (기본: https://ig-member.ig-pilot.com, 변경 시에만 설정)
# MEMBER_UI_BASE_URL=https://ig-member.ig-pilot.com

# MySQL (AWS Secret Manager prod/ignite-pilot/mysql-realpilot 참고)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bnk_mes
