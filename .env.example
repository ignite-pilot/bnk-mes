# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CloudWatch Logs (설정 시 로그 전송)
# CLOUDWATCH_LOG_GROUP=/bnk-mes/app
# CLOUDWATCH_REGION=ap-northeast-2
# CLOUDWATCH_LOG_STREAM=optional-stream-name
# AWS 인증: IAM 역할 또는 AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

# ig-member 화면 연동 (기본: https://ig-member.ig-pilot.com, 변경 시에만 설정)
# MEMBER_UI_BASE_URL=https://ig-member.ig-pilot.com

# 입고 요청 시 담당자 이메일 발송 (ig-notification: https://github.com/ignite-pilot/ig-notification)
# SMTP: 미설정 시 AWS Secrets Manager "prod/ignite-pilot/smtp-naver" 참고 (env 설정 시 env 우선)
# API: POST /api/v1/email/send (multipart/form-data)
# IG_NOTIFICATION_URL=https://ig-notification.ig-pilot.com
# IG_NOTIFICATION_SMTP_SECRET_ID=prod/ignite-pilot/smtp-naver  # SMTP 시크릿 ID (기본값)
# IG_NOTIFICATION_SENDER_EMAIL=  # env로 오버라이드 시 보내는 사람
# IG_NOTIFICATION_SMTP_HOST=     # env로 오버라이드 시 SMTP 호스트
# IG_NOTIFICATION_SMTP_PORT=    # env로 오버라이드 시 포트 (예: 587)
# IG_NOTIFICATION_SMTP_USERNAME=
# IG_NOTIFICATION_SMTP_PASSWORD=
# IG_NOTIFICATION_API_KEY=  # ig-notification API 인증이 필요하면 설정

# MySQL (AWS Secret Manager prod/ignite-pilot/mysql-realpilot 참고)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bnk_mes
