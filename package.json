{
  "name": "bnk-mes",
  "version": "1.0.0",
  "description": "BNS 생산 관리 시스템",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "test": "npm run test:server && npm run test:client",
    "test:server": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=server --forceExit",
    "test:client": "vitest run",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "setup:github": "node scripts/create-github-repo.js",
    "setup:mysql": "node scripts/create-mysql-db.js",
    "setup:raw-materials": "node scripts/create-raw-materials-table.js",
    "setup:material-types": "node scripts/create-material-types-table.js",
    "setup:material-suppliers": "node scripts/create-material-suppliers-table.js",
    "setup:supplier-address-fields": "node scripts/add-supplier-address-fields.js",
    "setup:supplier-manager-email": "node scripts/add-supplier-manager-email.js",
    "setup:supplier-warehouses": "node scripts/create-supplier-warehouses-table.js",
    "setup:material-stock": "node scripts/create-material-stock-tables.js",
    "setup:material-inbound": "node scripts/create-material-inbound-tables.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "mysql2": "^3.6.5",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "winston": "^3.11.0",
    "winston-cloudwatch": "^6.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jsdom": "^23.2.0",
    "supertest": "^6.3.4",
    "vite": "^5.0.10",
    "vitest": "^1.2.0"
  }
}
